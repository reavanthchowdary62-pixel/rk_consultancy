# RK Consultancy — Environment Variables
# Copy this file to .env.local and fill in your values

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# 1. Go to https://mongodb.com/atlas → Create Free Account
# 2. Create a FREE cluster (M0 - 512MB free forever)
# 3. Database → Connect → Connect your application → Copy the connection string
# 4. Replace <username>, <password>, and <dbname> below
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/rk-consultancy?retryWrites=true&w=majority

# ─── OpenAI (Optional - for AI Chatbot) ─────────────────────────────────────
# 1. Go to https://platform.openai.com/api-keys
# 2. Create an API key and paste it below
# Without this, the chatbot uses the built-in offline fallback mode
OPENAI_API_KEY=

# ─── Email via Resend (Optional - for Contact Form emails) ───────────────────
# 1. Go to https://resend.com → Sign up free (3000 emails/month free)
# 2. Create an API key
RESEND_API_KEY=

# ─── App Secret (Already set - do not share!) ────────────────────────────────
JWT_SECRET=your-secure-random-secret-here-at-least-32-chars
